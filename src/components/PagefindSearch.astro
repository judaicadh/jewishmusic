---
interface Props {
  /** Pagefind filter to scope results, e.g. "type:Album" */
  filter?: string;
  placeholder?: string;
}

const { filter, placeholder = 'Search…' } = Astro.props;

const types = ['Album', 'Artist', 'Composition', 'Label'];
const typeIcons: Record<string, string> = {
  Album: `<svg class="h-4 w-4" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><circle cx="12" cy="12" r="10"/><circle cx="12" cy="12" r="3"/></svg>`,
  Artist: `<svg class="h-4 w-4" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M19 21v-2a4 4 0 0 0-4-4H9a4 4 0 0 0-4 4v2"/><circle cx="12" cy="7" r="4"/></svg>`,
  Composition: `<svg class="h-4 w-4" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M9 18V5l12-2v13"/><circle cx="6" cy="18" r="3"/><circle cx="18" cy="16" r="3"/></svg>`,
  Label: `<svg class="h-4 w-4" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M12 2 2 7l10 5 10-5-10-5Z"/><path d="m2 17 10 5 10-5"/><path d="m2 12 10 5 10-5"/></svg>`,
};

const typeBadgeColors: Record<string, string> = {
  Album: 'bg-blue-100 text-blue-800 dark:bg-blue-900 dark:text-blue-200',
  Artist: 'bg-purple-100 text-purple-800 dark:bg-purple-900 dark:text-purple-200',
  Composition: 'bg-emerald-100 text-emerald-800 dark:bg-emerald-900 dark:text-emerald-200',
  Label: 'bg-amber-100 text-amber-800 dark:bg-amber-900 dark:text-amber-200',
};
---

<div id="pagefind-search" class="mb-8" data-filter={filter}>
  <!-- Search input -->
  <div class="relative">
    <input
      id="pf-input"
      type="text"
      placeholder={placeholder}
      class="w-full rounded-2xl border border-gray-200 bg-white px-4 py-3.5 pl-11 text-sm text-gray-900 shadow-sm outline-none focus:border-blue-400 focus:ring-2 focus:ring-blue-100 dark:border-gray-700 dark:bg-gray-900 dark:text-white dark:focus:border-blue-500 dark:focus:ring-blue-900"
    />
    <svg class="absolute left-3.5 top-3.5 h-5 w-5 text-gray-400" xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="2" stroke="currentColor">
      <path stroke-linecap="round" stroke-linejoin="round" d="m21 21-5.197-5.197m0 0A7.5 7.5 0 1 0 5.196 5.196a7.5 7.5 0 0 0 10.607 10.607Z" />
    </svg>
    <button id="pf-clear" class="absolute right-3 top-3 hidden rounded-full p-1 text-gray-400 hover:bg-gray-100 hover:text-gray-600 dark:hover:bg-gray-800 dark:hover:text-gray-200" aria-label="Clear search">
      <svg class="h-4 w-4" xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="2" stroke="currentColor">
        <path stroke-linecap="round" stroke-linejoin="round" d="M6 18 18 6M6 6l12 12" />
      </svg>
    </button>
  </div>

  {/* Filter chips — only show on unfiltered pages (explore, etc.) */}
  {!filter && (
    <div id="pf-filters" class="mt-4 flex flex-wrap gap-2">
      <button data-pf-type="all" class="pf-chip pf-chip-active inline-flex items-center gap-2 rounded-full border px-3.5 py-2 text-sm font-medium transition">
        All
      </button>
      {types.map((t) => (
        <button data-pf-type={t} class="pf-chip inline-flex items-center gap-2 rounded-full border px-3.5 py-2 text-sm font-medium transition">
          <Fragment set:html={typeIcons[t]} />
          {t === 'Label' ? 'Labels' : `${t}s`}
        </button>
      ))}
    </div>
  )}

  <!-- Results area -->
  <div id="pf-results" class="mt-6 hidden">
    <p id="pf-summary" class="mb-4 text-sm font-medium text-gray-500 dark:text-gray-400"></p>
    <div id="pf-list" class="grid grid-cols-1 gap-4 sm:grid-cols-2 lg:grid-cols-3 xl:grid-cols-4"></div>
  </div>
</div>

<style>
  .pf-chip {
    border-color: rgb(229 231 235);
    background: white;
    color: rgb(107 114 128);
  }
  .pf-chip:hover {
    border-color: rgb(147 197 253);
    color: rgb(29 78 216);
    background: rgb(239 246 255);
  }
  .pf-chip-active {
    border-color: rgb(96 165 250) !important;
    background: rgb(219 234 254) !important;
    color: rgb(29 78 216) !important;
  }
  :global(.dark) .pf-chip {
    border-color: rgb(55 65 81);
    background: rgb(17 24 39);
    color: rgb(156 163 175);
  }
  :global(.dark) .pf-chip:hover {
    border-color: rgb(59 130 246);
    color: rgb(147 197 253);
    background: rgb(30 58 138 / 0.3);
  }
  :global(.dark) .pf-chip-active {
    border-color: rgb(59 130 246) !important;
    background: rgb(30 58 138 / 0.4) !important;
    color: rgb(147 197 253) !important;
  }
</style>

<script is:inline>
(function() {
  let pagefind = null;
  const container = document.getElementById('pagefind-search');
  const input = document.getElementById('pf-input');
  const clear = document.getElementById('pf-clear');
  const results = document.getElementById('pf-results');
  const summary = document.getElementById('pf-summary');
  const list = document.getElementById('pf-list');
  const filterAttr = container?.dataset.filter;
  function getBrowseContent() { return document.getElementById('browse-content'); }

  let debounce = null;
  let activeType = 'all';

  const badgeColors = {
    Album: 'background:rgb(219 234 254);color:rgb(30 64 175);',
    Artist: 'background:rgb(243 232 255);color:rgb(107 33 168);',
    Composition: 'background:rgb(209 250 229);color:rgb(6 95 70);',
    Label: 'background:rgb(254 243 199);color:rgb(146 64 14);',
  };

  const defaultImages = {
    Album: '<svg class="h-8 w-8 text-blue-400" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5"><circle cx="12" cy="12" r="10"/><circle cx="12" cy="12" r="3"/></svg>',
    Artist: '<svg class="h-8 w-8 text-purple-400" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5"><path d="M19 21v-2a4 4 0 0 0-4-4H9a4 4 0 0 0-4 4v2"/><circle cx="12" cy="7" r="4"/></svg>',
    Composition: '<svg class="h-8 w-8 text-emerald-400" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5"><path d="M9 18V5l12-2v13"/><circle cx="6" cy="18" r="3"/><circle cx="18" cy="16" r="3"/></svg>',
    Label: '<svg class="h-8 w-8 text-amber-400" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5"><path d="M12 2 2 7l10 5 10-5-10-5Z"/><path d="m2 17 10 5 10-5"/><path d="m2 12 10 5 10-5"/></svg>',
  };

  // Chip click handlers
  const chips = document.querySelectorAll('.pf-chip');
  chips.forEach(chip => {
    chip.addEventListener('click', () => {
      chips.forEach(c => c.classList.remove('pf-chip-active'));
      chip.classList.add('pf-chip-active');
      activeType = chip.dataset.pfType;
      const q = input.value.trim();
      if (q.length >= 2) search(q);
    });
  });

  async function init() {
    if (pagefind) return;
    pagefind = await import('/pagefind/pagefind.js');
    await pagefind.init();
  }

  async function search(query) {
    await init();
    const filters = {};
    if (filterAttr) {
      const [k, v] = filterAttr.split(':');
      filters[k] = v;
    } else if (activeType !== 'all') {
      filters.type = activeType;
    }
    const result = await pagefind.search(query, { filters });
    const total = result.results.length;
    const typeLabel = activeType === 'all' ? '' : ` in ${activeType}s`;
    summary.textContent = `${total} result${total === 1 ? '' : 's'} for "${query}"${typeLabel}`;

    const items = await Promise.all(result.results.slice(0, 40).map(r => r.data()));
    list.innerHTML = items.map(item => {
      const type = item.filters?.type?.[0] || 'Album';
      const title = item.meta?.title || 'Untitled';
      const cover = item.meta?.cover;
      const badge = badgeColors[type] || badgeColors.Album;
      const routePrefix = type.toLowerCase();
      const url = item.url || `/${routePrefix}/`;
      const fallbackIcon = defaultImages[type] || defaultImages.Album;

      const imageHtml = cover
        ? `<img src="${cover}" alt="" loading="lazy" class="aspect-square w-full object-cover transition group-hover:scale-105" />`
        : `<div class="aspect-square w-full flex items-center justify-center bg-gray-100 dark:bg-gray-800">${fallbackIcon}</div>`;

      return `<a href="${url}" class="group block overflow-hidden rounded-2xl border border-gray-200 bg-white shadow-sm transition hover:border-blue-300 hover:shadow-md dark:border-gray-800 dark:bg-gray-900 dark:hover:border-blue-600">
        <div class="relative overflow-hidden">
          ${imageHtml}
          <span class="absolute top-2.5 left-2.5 rounded-full px-2.5 py-1 text-[11px] font-semibold" style="${badge}">${type}</span>
        </div>
        <div class="p-3.5">
          <h3 class="line-clamp-2 text-sm font-semibold text-gray-900 group-hover:text-blue-700 dark:text-white dark:group-hover:text-blue-400">${title}</h3>
          ${item.excerpt ? `<p class="mt-1 line-clamp-2 text-xs text-gray-500 dark:text-gray-400">${item.excerpt}</p>` : ''}
        </div>
      </a>`;
    }).join('');
    results.classList.remove('hidden');
    getBrowseContent()?.classList.add('hidden');
  }

  function reset() {
    results.classList.add('hidden');
    list.innerHTML = '';
    summary.textContent = '';
    clear.classList.add('hidden');
    getBrowseContent()?.classList.remove('hidden');
  }

  input.addEventListener('input', () => {
    clearTimeout(debounce);
    const q = input.value.trim();
    if (q.length < 2) { reset(); return; }
    clear.classList.remove('hidden');
    debounce = setTimeout(() => search(q), 200);
  });

  clear.addEventListener('click', () => {
    input.value = '';
    reset();
    input.focus();
  });
})();
</script>
