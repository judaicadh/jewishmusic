---
/**
 * Pagefind search box + faceted results. The Pagefind index lives at
 * /pagefind/, which is generated by `pagefind --site dist` AFTER `astro build`
 * (see package.json). It therefore only works in a built/preview site, NOT in
 * `astro dev`. Test with: npm run build && npm run preview.
 */
---

<div id="search"></div>

<link href="/pagefind/pagefind-ui.css" rel="stylesheet" />
<script is:inline src="/pagefind/pagefind-ui.js"></script>
<script is:inline>
  function initPagefind() {
    if (typeof PagefindUI === 'undefined') return;
    new PagefindUI({
      element: '#search',
      showImages: true,
      showSubResults: true,
      pageSize: 12,
      resetStyles: false,
      filters: { type: 'all', year: 'all', performer: 'all', label: 'all' },
    });
  }
  // Run on first load and on Astro View Transition navigations.
  document.addEventListener('astro:page-load', initPagefind);
  if (document.readyState !== 'loading') initPagefind();
  else document.addEventListener('DOMContentLoaded', initPagefind);
</script>

<style is:global>
  /* Tune Pagefind UI to the site's palette */
  :root {
    --pagefind-ui-primary: #1d4ed8;
    --pagefind-ui-font: inherit;
    --pagefind-ui-border-radius: 1rem;
  }
</style>
