---
import BaseLayout from '../layouts/BaseLayout.astro';
import PagefindSearch from '../components/PagefindSearch.astro';
---

<BaseLayout title="Explore">
  <section class="mx-auto max-w-7xl px-4 py-12 sm:px-6 lg:px-8">
    <p class="text-sm font-semibold uppercase tracking-wide text-blue-700 dark:text-blue-400">Explore</p>
    <h1 class="mt-2 text-4xl font-semibold tracking-tight text-gray-900 dark:text-white">
      Explore the catalog
    </h1>
    <p class="mt-4 mb-8 text-lg leading-8 text-gray-700 dark:text-gray-300">
      Search and filter across all albums, artists, compositions, and labels.
    </p>

    <PagefindSearch faceted placeholder="Search the entire collection…" />
  </section>
</BaseLayout>
