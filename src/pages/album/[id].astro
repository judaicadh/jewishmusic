---
import BaseLayout from '../../layouts/BaseLayout.astro';
import { getAllAlbums, type Album } from '../../lib/wikibase';

// Static generation, one page per album, sourced live from the Shira Wikibase.
// The entire catalog is loaded once via two bulk queries (getAllAlbums), so this
// no longer fires per-page requests. Set ALBUM_LIMIT to cap pages during dev.
export async function getStaticPaths() {
  const all = [...(await getAllAlbums()).values()];
  const limit = process.env.ALBUM_LIMIT ? Number(process.env.ALBUM_LIMIT) : undefined;
  return (limit ? all.slice(0, limit) : all).map((album) => ({
    params: { id: album.id },
    props: { album },
  }));
}

const { album } = Astro.props as { album: Album };

const pageTitle = album.title || album.freedmanTitle || album.id;

const spotifyEmbed = album.spotifyAlbumId
  ? `https://open.spotify.com/embed/album/${album.spotifyAlbumId}`
  : undefined;
const youtubeEmbed = album.youtubePlaylistId
  ? `https://www.youtube.com/embed/videoseries?list=${album.youtubePlaylistId}`
  : undefined;

// Internet Archive: one id yields both cover art and an embeddable audio player.
const iaId = album.internetArchiveId;
const iaImage = iaId ? `https://archive.org/services/img/${iaId}` : undefined;
const iaEmbed = iaId ? `https://archive.org/embed/${iaId}` : undefined;

const discogsUrl = album.discogsReleaseId
  ? `https://www.discogs.com/release/${album.discogsReleaseId}`
  : undefined;
const entityUrl = `https://shira.wikibase.cloud/wiki/Item:${album.id}`;

const pubYear = album.publicationDate?.slice(0, 4)?.replace(/^\+/, '');
// Cover precedence: Internet Archive → Discogs (P160) → placeholder.
const coverImage = iaImage ?? album.cover ?? '/placeholder.jpg';

// External archive / listen links, in display order.
const externalLinks = [
  album.dartmouthUrl && { label: 'Dartmouth Jewish Sound Archive', href: album.dartmouthUrl },
  album.rsaUrl && { label: 'Recorded Sound Archives', href: album.rsaUrl },
  discogsUrl && { label: 'Discogs', href: discogsUrl },
].filter(Boolean) as Array<{ label: string; href: string }>;
---

<BaseLayout title={pageTitle}>
  <section
    class="bg-white py-8 antialiased dark:bg-gray-950 md:py-12"
    data-pagefind-body
    data-pagefind-meta={`title:${pageTitle}`}
  >
    {/* Pagefind facets (indexed, not rendered) */}
    <span hidden data-pagefind-filter="type:Album"></span>
    {pubYear && <span hidden data-pagefind-filter={`year:${pubYear}`}></span>}
    {album.performers.map((p) => (
      <span hidden data-pagefind-filter={`performer:${p.label}`}></span>
    ))}
    {album.recordLabels.map((l) => (
      <span hidden data-pagefind-filter={`label:${l.label}`}></span>
    ))}
    <div class="mx-auto max-w-7xl px-4 sm:px-6 lg:px-8">
      <div class="grid gap-10 lg:grid-cols-[360px_minmax(0,1fr)] lg:items-start">
        <aside class="space-y-5">
          <div class="overflow-hidden rounded-3xl border border-gray-200 bg-gray-50 shadow-sm dark:border-gray-800 dark:bg-gray-900">
            <img src={coverImage} alt={pageTitle} data-pagefind-meta="image[src]" class="aspect-square w-full object-cover" />
          </div>

          {iaEmbed && (
            <div class="rounded-3xl border border-gray-200 bg-white p-4 shadow-sm dark:border-gray-800 dark:bg-gray-900">
              <h2 class="mb-3 text-sm font-semibold uppercase tracking-wide text-gray-500 dark:text-gray-400">Listen — Internet Archive</h2>
              <iframe
                src={iaEmbed}
                class="h-[150px] w-full rounded-2xl border-0"
                loading="lazy"
                allow="autoplay"
              ></iframe>
            </div>
          )}

          {spotifyEmbed && (
            <div class="rounded-3xl border border-gray-200 bg-white p-4 shadow-sm dark:border-gray-800 dark:bg-gray-900">
              <h2 class="mb-3 text-sm font-semibold uppercase tracking-wide text-gray-500 dark:text-gray-400">Listen — Spotify</h2>
              <iframe
                src={spotifyEmbed}
                class="h-[352px] w-full rounded-2xl border-0"
                loading="lazy"
                allow="autoplay; clipboard-write; encrypted-media; fullscreen; picture-in-picture"
              ></iframe>
            </div>
          )}

          {youtubeEmbed && (
            <div class="rounded-3xl border border-gray-200 bg-white p-4 shadow-sm dark:border-gray-800 dark:bg-gray-900">
              <h2 class="mb-3 text-sm font-semibold uppercase tracking-wide text-gray-500 dark:text-gray-400">Watch</h2>
              <iframe
                src={youtubeEmbed}
                class="aspect-video w-full rounded-2xl border-0"
                loading="lazy"
                allow="autoplay; encrypted-media; picture-in-picture"
                allowfullscreen
              ></iframe>
            </div>
          )}

          {externalLinks.length > 0 && (
            <div class="rounded-3xl border border-gray-200 bg-white p-4 shadow-sm dark:border-gray-800 dark:bg-gray-900">
              <h2 class="mb-3 text-sm font-semibold uppercase tracking-wide text-gray-500 dark:text-gray-400">Archives &amp; links</h2>
              <ul class="space-y-2 text-sm">
                {externalLinks.map((l) => (
                  <li>
                    <a href={l.href} target="_blank" rel="noreferrer" class="font-medium text-blue-700 hover:underline dark:text-blue-400">{l.label} ↗</a>
                  </li>
                ))}
              </ul>
            </div>
          )}
        </aside>

        <div class="space-y-8">
          <header class="space-y-5">
            <div class="flex flex-wrap items-center gap-2">
              <span class="rounded-full bg-blue-50 px-3 py-1 text-xs font-semibold uppercase tracking-wide text-blue-700 dark:bg-blue-500/10 dark:text-blue-300">Album</span>
              {album.catalogNumber && (
                <span class="rounded-full bg-gray-100 px-3 py-1 text-xs font-medium text-gray-700 dark:bg-gray-800 dark:text-gray-300">Catalog no. {album.catalogNumber}</span>
              )}
              {pubYear && (
                <span class="rounded-full bg-gray-100 px-3 py-1 text-xs font-medium text-gray-700 dark:bg-gray-800 dark:text-gray-300">{pubYear}</span>
              )}
            </div>

            <div>
              <h1 class="text-3xl font-semibold tracking-tight text-gray-900 dark:text-white sm:text-4xl">{pageTitle}</h1>
              {album.freedmanTitle && album.freedmanTitle !== pageTitle && (
                <p class="mt-2 text-sm text-gray-500 dark:text-gray-400">Freedman title: {album.freedmanTitle}</p>
              )}
            </div>

            {album.performers.length > 0 && (
              <div>
                <h2 class="mb-2 text-sm font-semibold uppercase tracking-wide text-gray-500 dark:text-gray-400">Artists</h2>
                <div class="flex flex-wrap gap-2">
                  {album.performers.map((artist) =>
                    artist.id ? (
                      <a
                        href={`/artist/${artist.id}`}
                        class="rounded-full border border-gray-200 px-3 py-1.5 text-sm font-medium text-gray-800 transition hover:border-blue-400 hover:text-blue-700 dark:border-gray-700 dark:text-gray-200 dark:hover:border-blue-500 dark:hover:text-blue-300"
                      >{artist.label}</a>
                    ) : (
                      <span class="rounded-full border border-gray-200 px-3 py-1.5 text-sm font-medium text-gray-800 dark:border-gray-700 dark:text-gray-200">{artist.label}</span>
                    )
                  )}
                </div>
              </div>
            )}
          </header>

          <div class="grid gap-4 md:grid-cols-3">
            <div class="rounded-3xl border border-gray-200 bg-white p-5 shadow-sm dark:border-gray-800 dark:bg-gray-900">
              <dt class="text-xs font-semibold uppercase tracking-wide text-gray-500 dark:text-gray-400">Tracks</dt>
              <dd class="mt-2 text-2xl font-semibold text-gray-900 dark:text-white">{album.tracks.length || '—'}</dd>
            </div>
            <div class="rounded-3xl border border-gray-200 bg-white p-5 shadow-sm dark:border-gray-800 dark:bg-gray-900">
              <dt class="text-xs font-semibold uppercase tracking-wide text-gray-500 dark:text-gray-400">Label</dt>
              <dd class="mt-2 truncate text-lg font-semibold text-gray-900 dark:text-white">{album.recordLabels[0]?.label ?? '—'}</dd>
            </div>
            <div class="rounded-3xl border border-gray-200 bg-white p-5 shadow-sm dark:border-gray-800 dark:bg-gray-900">
              <dt class="text-xs font-semibold uppercase tracking-wide text-gray-500 dark:text-gray-400">Media</dt>
              <dd class="mt-2 text-2xl font-semibold text-gray-900 dark:text-white">{spotifyEmbed || youtubeEmbed ? 'Playable' : 'Metadata only'}</dd>
            </div>
          </div>

          <div class="grid gap-6 xl:grid-cols-[minmax(0,1fr)_320px]">
            <section class="rounded-3xl border border-gray-200 bg-white p-6 shadow-sm dark:border-gray-800 dark:bg-gray-900">
              <div class="mb-4 flex items-center justify-between gap-3">
                <h2 class="text-lg font-semibold text-gray-900 dark:text-white">Track list</h2>
                <span class="text-sm text-gray-500 dark:text-gray-400">{album.tracks.length} tracks</span>
              </div>

              {album.tracks.length > 0 ? (
                <ol class="space-y-2">
                  {album.tracks.map((track, i) => (
                    <li class="flex items-center justify-between gap-4 rounded-2xl border border-gray-100 px-4 py-3 dark:border-gray-800">
                      <div class="flex min-w-0 items-center gap-3">
                        <span class="flex h-8 w-8 shrink-0 items-center justify-center rounded-full bg-gray-100 text-xs font-semibold text-gray-600 dark:bg-gray-800 dark:text-gray-300">{i + 1}</span>
                        {track.id ? (
                          <a href={`/composition/${track.id}`} class="truncate font-medium text-gray-900 hover:text-blue-700 hover:underline dark:text-white dark:hover:text-blue-300">{track.label}</a>
                        ) : (
                          <span class="truncate font-medium text-gray-900 dark:text-white">{track.label}</span>
                        )}
                      </div>
                      {track.duration && (
                        <span class="shrink-0 text-sm tabular-nums text-gray-500 dark:text-gray-400">{track.duration}</span>
                      )}
                    </li>
                  ))}
                </ol>
              ) : (
                <p class="text-gray-600 dark:text-gray-400">No track list is available for this album yet.</p>
              )}
            </section>

            <aside class="space-y-6">
              <section class="rounded-3xl border border-gray-200 bg-white p-6 shadow-sm dark:border-gray-800 dark:bg-gray-900">
                <h2 class="text-lg font-semibold text-gray-900 dark:text-white">Metadata</h2>
                <dl class="mt-4 space-y-4 text-sm">
                  <div>
                    <dt class="font-semibold text-gray-500 dark:text-gray-400">Title</dt>
                    <dd class="mt-1 text-gray-900 dark:text-white">{pageTitle}</dd>
                  </div>
                  {album.catalogNumber && (
                    <div>
                      <dt class="font-semibold text-gray-500 dark:text-gray-400">Catalog number</dt>
                      <dd class="mt-1 text-gray-900 dark:text-white">{album.catalogNumber}</dd>
                    </div>
                  )}
                  {album.publicationDate && (
                    <div>
                      <dt class="font-semibold text-gray-500 dark:text-gray-400">Publication date</dt>
                      <dd class="mt-1 text-gray-900 dark:text-white">{pubYear}</dd>
                    </div>
                  )}
                  {album.recordLabels.length > 0 && (
                    <div>
                      <dt class="font-semibold text-gray-500 dark:text-gray-400">Record label</dt>
                      <dd class="mt-1 flex flex-wrap gap-2">
                        {album.recordLabels.map((l) =>
                          l.id ? (
                            <a href={`/label/${l.id}`} class="rounded-full bg-gray-100 px-2.5 py-1 text-gray-700 hover:text-blue-700 dark:bg-gray-800 dark:text-gray-300 dark:hover:text-blue-300">{l.label}</a>
                          ) : (
                            <span class="rounded-full bg-gray-100 px-2.5 py-1 text-gray-700 dark:bg-gray-800 dark:text-gray-300">{l.label}</span>
                          )
                        )}
                      </dd>
                    </div>
                  )}
                </dl>
              </section>

              <section class="rounded-3xl border border-gray-200 bg-white p-6 shadow-sm dark:border-gray-800 dark:bg-gray-900">
                <h2 class="text-lg font-semibold text-gray-900 dark:text-white">Links</h2>
                <ul class="mt-4 space-y-2 text-sm">
                  {discogsUrl && (
                    <li><a href={discogsUrl} target="_blank" rel="noreferrer" class="font-medium text-blue-700 hover:underline dark:text-blue-400">Discogs release ↗</a></li>
                  )}
                  {album.freedmanAlbumId && (
                    <li class="text-gray-600 dark:text-gray-400">Freedman Album ID: {album.freedmanAlbumId}</li>
                  )}
                  <li><a href={entityUrl} target="_blank" rel="noreferrer" class="font-medium text-blue-700 hover:underline dark:text-blue-400">View in Wikibase ({album.id}) ↗</a></li>
                </ul>
              </section>
            </aside>
          </div>
        </div>
      </div>
    </div>
  </section>
</BaseLayout>
