---
import BaseLayout from '../../layouts/BaseLayout.astro';
import { getAllCompositions, type Composition } from '../../lib/wikibase';

export async function getStaticPaths() {
  const all = [...(await getAllCompositions()).values()];
  const limit = process.env.ALBUM_LIMIT ? Number(process.env.ALBUM_LIMIT) : undefined;
  return (limit ? all.slice(0, limit) : all).map((composition) => ({
    params: { composition: composition.id },
    props: { composition },
  }));
}

const { composition } = Astro.props as { composition: Composition };
const entityUrl = `https://shira.wikibase.cloud/wiki/Item:${composition.id}`;

// Collect all unique albums: from recordings (with cover art) and direct appearances.
const albumMap = new Map<string, { id: string; title: string; cover?: string; tracks: string[] }>();
for (const rec of composition.recordings) {
  for (const al of rec.albums) {
    const existing = albumMap.get(al.id);
    if (existing) {
      if (!existing.tracks.includes(rec.title)) existing.tracks.push(rec.title);
    } else {
      albumMap.set(al.id, { id: al.id, title: al.title, cover: al.cover, tracks: [rec.title] });
    }
  }
}
for (const ap of composition.appearsOn) {
  if (!albumMap.has(ap.albumId)) {
    albumMap.set(ap.albumId, { id: ap.albumId, title: ap.albumTitle, tracks: [] });
  }
}
const allAlbums = [...albumMap.values()].sort(
  (a, b) => (b.cover ? 1 : 0) - (a.cover ? 1 : 0) || a.title.localeCompare(b.title)
);
---

<BaseLayout title={composition.title}>
  <section class="mx-auto max-w-5xl px-4 py-8 sm:px-6 lg:px-8" data-pagefind-body data-pagefind-filter="type:Composition" data-pagefind-meta="type:Composition">
    <header class="mb-10">
      <span class="rounded-full bg-emerald-50 px-3 py-1 text-xs font-semibold uppercase tracking-wide text-emerald-700 dark:bg-emerald-500/10 dark:text-emerald-300">{composition.type ?? 'Composition'}</span>
      <h1 class="mt-3 text-3xl font-semibold tracking-tight text-gray-900 dark:text-white sm:text-4xl">{composition.title}</h1>

      <div class="mt-4 flex flex-wrap items-center gap-x-6 gap-y-3">
        {composition.composers.length > 0 && (
          <div class="flex items-center gap-2">
            <span class="text-xs font-semibold uppercase tracking-wide text-gray-500 dark:text-gray-400">Composer</span>
            <div class="flex flex-wrap gap-1.5">
              {composition.composers.map((c) =>
                c.id ? (
                  <a href={`/artist/${c.id}/`} class="rounded-full bg-emerald-100 px-2.5 py-1 text-xs font-medium text-emerald-800 hover:bg-emerald-200 dark:bg-emerald-900 dark:text-emerald-200 dark:hover:bg-emerald-800">{c.label}</a>
                ) : (
                  <span class="rounded-full bg-emerald-100 px-2.5 py-1 text-xs font-medium text-emerald-800 dark:bg-emerald-900 dark:text-emerald-200">{c.label}</span>
                )
              )}
            </div>
          </div>
        )}
        {composition.performers.length > 0 && (
          <div class="flex items-center gap-2">
            <span class="text-xs font-semibold uppercase tracking-wide text-gray-500 dark:text-gray-400">Performers</span>
            <div class="flex flex-wrap gap-1.5">
              {composition.performers.map((p) =>
                p.id ? (
                  <a href={`/artist/${p.id}/`} class="rounded-full bg-gray-100 px-2.5 py-1 text-xs font-medium text-gray-700 hover:bg-gray-200 dark:bg-gray-800 dark:text-gray-300 dark:hover:bg-gray-700">{p.label}</a>
                ) : (
                  <span class="rounded-full bg-gray-100 px-2.5 py-1 text-xs font-medium text-gray-700 dark:bg-gray-800 dark:text-gray-300">{p.label}</span>
                )
              )}
            </div>
          </div>
        )}
      </div>

      <a href={entityUrl} target="_blank" rel="noreferrer" class="mt-4 inline-block text-sm font-medium text-blue-700 hover:underline dark:text-blue-400">View in Wikibase ({composition.id}) ↗</a>
    </header>

    {allAlbums.length > 0 ? (
      <div>
        <h2 class="mb-2 text-lg font-semibold text-gray-900 dark:text-white">
          Albums featuring this work <span class="text-sm font-normal text-gray-500 dark:text-gray-400">({allAlbums.length})</span>
        </h2>
        <p class="mb-6 text-sm text-gray-500 dark:text-gray-400">
          Recordings and performances of <span class="font-medium text-gray-700 dark:text-gray-300">{composition.title}</span> appear on these albums.
        </p>
        <div class="grid grid-cols-2 gap-4 sm:grid-cols-3 md:grid-cols-4 lg:grid-cols-5">
          {allAlbums.map((al) => (
            <a href={`/album/${al.id}/`} class="group block">
              <div class="overflow-hidden rounded-2xl border border-gray-200 bg-gray-50 shadow-sm dark:border-gray-800 dark:bg-gray-900">
                <img
                  src={al.cover || '/placeholder.jpg'}
                  alt=""
                  loading="lazy"
                  class="aspect-square w-full object-cover transition group-hover:scale-105"
                />
              </div>
              <p class="mt-2 line-clamp-2 text-sm font-medium text-gray-800 group-hover:text-blue-700 dark:text-gray-200 dark:group-hover:text-blue-400">{al.title}</p>
              {al.tracks.length > 0 && (
                <p class="line-clamp-1 text-xs text-gray-500 dark:text-gray-400">
                  {al.tracks.length === 1 ? al.tracks[0] : `${al.tracks.length} recordings`}
                </p>
              )}
            </a>
          ))}
        </div>
      </div>
    ) : (
      <p class="text-gray-600 dark:text-gray-400">No catalogued recordings of this work yet.</p>
    )}
  </section>
</BaseLayout>
