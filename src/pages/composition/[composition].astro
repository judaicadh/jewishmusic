---
import BaseLayout from '../../layouts/BaseLayout.astro';
import { getAllCompositions, type Composition } from '../../lib/wikibase';

export async function getStaticPaths() {
  const all = [...(await getAllCompositions()).values()];
  const limit = process.env.ALBUM_LIMIT ? Number(process.env.ALBUM_LIMIT) : undefined;
  return (limit ? all.slice(0, limit) : all).map((composition) => ({
    params: { composition: composition.id },
    props: { composition },
  }));
}

const { composition } = Astro.props as { composition: Composition };
const entityUrl = `https://shira.wikibase.cloud/wiki/Item:${composition.id}`;
---

<BaseLayout title={composition.title}>
  <section
    class="mx-auto max-w-3xl px-4 py-8 sm:px-6 lg:px-8"
    data-pagefind-body
    data-pagefind-meta={`title:${composition.title}`}
  >
    <span hidden data-pagefind-filter="type:Composition"></span>

    <header class="mb-8">
      <span class="rounded-full bg-emerald-50 px-3 py-1 text-xs font-semibold uppercase tracking-wide text-emerald-700 dark:bg-emerald-500/10 dark:text-emerald-300">{composition.type ?? 'Composition'}</span>
      <h1 class="mt-3 text-3xl font-semibold tracking-tight text-gray-900 dark:text-white sm:text-4xl">{composition.title}</h1>
      <a href={entityUrl} target="_blank" rel="noreferrer" class="mt-3 inline-block text-sm font-medium text-blue-700 hover:underline dark:text-blue-400">View in Wikibase ({composition.id}) ↗</a>
    </header>

    {composition.performers.length > 0 && (
      <div class="mb-8">
        <h2 class="mb-2 text-sm font-semibold uppercase tracking-wide text-gray-500 dark:text-gray-400">Performers</h2>
        <div class="flex flex-wrap gap-2">
          {composition.performers.map((p) =>
            p.id ? (
              <a href={`/artist/${p.id}`} class="rounded-full border border-gray-200 px-3 py-1.5 text-sm font-medium text-gray-800 hover:border-blue-400 hover:text-blue-700 dark:border-gray-700 dark:text-gray-200">{p.label}</a>
            ) : (
              <span class="rounded-full border border-gray-200 px-3 py-1.5 text-sm font-medium text-gray-800 dark:border-gray-700 dark:text-gray-200">{p.label}</span>
            )
          )}
        </div>
      </div>
    )}

    <h2 class="mb-4 text-lg font-semibold text-gray-900 dark:text-white">
      {composition.appearsOn.length > 0 ? 'Appears on' : 'Recordings'}
    </h2>
    {composition.appearsOn.length > 0 ? (
      <ul class="space-y-2">
        {composition.appearsOn.map((a) => (
          <li class="rounded-2xl border border-gray-100 px-4 py-3 dark:border-gray-800">
            <a href={`/album/${a.albumId}`} class="flex items-center justify-between gap-4">
              <span class="font-medium text-gray-900 hover:text-blue-700 hover:underline dark:text-white dark:hover:text-blue-300">{a.albumTitle}</span>
              <span class="shrink-0 text-sm text-gray-500 dark:text-gray-400">track {a.ordinal}</span>
            </a>
          </li>
        ))}
      </ul>
    ) : (
      <p class="text-gray-600 dark:text-gray-400">No catalogued recordings of this work yet.</p>
    )}
  </section>
</BaseLayout>
